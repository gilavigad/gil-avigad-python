def list_statistics(data):
    try:
        if not data:
            raise ValueError("List is empty.")

    
        numbers = []
        for item in data:
            try:
                numbers.append(float(item))
            except ValueError:
                raise ValueError(f"Non-numeric value found: {item}")

        total = sum(numbers)
        avg = total / len(numbers)
        minimum = min(numbers)
        maximum = max(numbers)

        return {
            "sum": total,
            "average": avg,
            "min": minimum,
            "max": maximum
        }

    except ValueError as e:
        return f"Error: {e}"


print(list_statistics([1, 2, 3, 4, 5]))       
print(list_statistics([]))                    
print(list_statistics([1, "a", 3]))           
