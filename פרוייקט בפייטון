def show_location(current_location, locations):
    loc = locations[current_location]
    print("\nLocation:", current_location)
    print(loc["description"])
    print("Exits:", list(loc["exits"].keys()))
    
    if loc["items"]:
        print("Items:", loc["items"])
    else:
        print("No items here")

def show_inventory(inventory):
    if not inventory:
        print("Inventory is empty")
    else:
        print("Inventory:", inventory)

