def play_game():
    current_location = "entrance"
    inventory = []
    moves = 0

    show_intro()
    show_commands()

    while True:
        show_location(current_location, locations)

        command = input("> ").lower().strip()

        if command == "quit":
            print("Goodbye")
            break

        elif command == "look":
            continue

        elif command == "inventory":
            show_inventory(inventory)

        elif command == "help":
            show_commands()

        elif command.startswith("go "):
            parts = command.split()
            direction = parts[1]
            current_location = go_direction(current_location, direction, locations)
            moves += 1

        elif command.startswith("take "):
            parts = command.split()
            item = parts[1]
            take_item(current_location, item, inventory, locations)

        else:
            print("Unknown command")

        if check_win(inventory):
            print("You found the treasure and won the game")
            print("Total moves:", moves)
            break

