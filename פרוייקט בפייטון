def get_response(message, user_name):
    message_lower = message.lower()

    if "hello" in message_lower or "hi" in message_lower:
        return random.choice(greetings) + " " + user_name

    elif "how are you" in message_lower:
        return "I am doing well"

    elif "your name" in message_lower:
        return "My name is " + bot_name

    elif "joke" in message_lower:
        return tell_joke()

    elif "game" in message_lower:
        return "game_menu"

    elif "help" in message_lower:
        show_help()
        return "What else do you need"

    elif "+" in message_lower or "-" in message_lower or "*" in message_lower:
        try:
            return str(eval(message))
        except:
            return "Math error"

    mood = analyze_mood(message)
    if mood == "happy":
        return "That is great to hear"
    elif mood == "sad":
        return "I hope things get better"

    return "Tell me more"

