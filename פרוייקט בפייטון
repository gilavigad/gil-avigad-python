def play_guess_game():
    number = random.randint(1, 20)
    attempts = 0

    while True:
        guess = input("Guess a number between 1-20: ")

        try:
            guess = int(guess)
            attempts += 1

            if guess < number:
                print("Too low")
            elif guess > number:
                print("Too high")
            else:
                return "Correct! Attempts: " + str(attempts)

        except:
            print("Enter a valid number")

