def chat():
    user_name = greet_user()
    show_help()

    while True:
        user_message = input(user_name + ": ").strip()

        if not user_message:
            continue

        if "bye" in user_message.lower():
            print_bot(random.choice(goodbyes) + " " + user_name)
            break

        response = get_response(user_message, user_name)

        if response == "game_menu":
            print("1. Guessing Game")
            print("2. Exit")

            choice = input("Choose: ")

            if choice == "1":
                result = play_guess_game()
                print_bot(result)
            else:
                print_bot("Maybe later")

        else:
            print_bot(response)

chat() 

