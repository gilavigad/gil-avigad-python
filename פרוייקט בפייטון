def take_item(current_location, item_name, inventory, locations):
    if item_name in locations[current_location]["items"]:
        locations[current_location]["items"].remove(item_name)
        inventory.append(item_name)
        print(item_name, "taken")
    else:
        print("Item not found")

def go_direction(current_location, direction, locations):
    if direction in locations[current_location]["exits"]:
        return locations[current_location]["exits"][direction]
    else:
        print("You cannot go that way")
        return current_location

def check_win(inventory):
    return "treasure" in inventory

