def analyze_mood(message):
    happy_words = ["happy", "great", "good", "awesome", "fun"]
    sad_words = ["sad", "bad", "terrible", "angry", "upset"]

    message = message.lower()

    for word in happy_words:
        if word in message:
            return "happy"

    for word in sad_words:
        if word in message:
            return "sad"

    return "neutral"

print("Mood test:", analyze_mood("I feel great today"))


